GROQ_API_KEY=

# Optional Sentry runtime instrumentation
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=

# Optional Sentry source-map upload during vercel-build
SENTRY_UPLOAD_SOURCE_MAPS=0
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Recommended for Node stack traces when running built output
NODE_OPTIONS=--enable-source-maps

# Optional canonical frontend/app URL
APP_URL=http://localhost:3000

# Optional extra CORS origins, comma-separated
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional VoltOps integration
VOLTAGENT_PUBLIC_KEY=
VOLTAGENT_SECRET_KEY=

# Storage mode:
# - local default: libsql
# - Vercel default: memory
# Set explicitly to override.
VOLTAGENT_STORAGE_MODE=

# Optional remote LibSQL/Turso for persistent Vercel memory/observability
LIBSQL_URL=
LIBSQL_AUTH_TOKEN=
LIBSQL_OBSERVABILITY_URL=
LIBSQL_OBSERVABILITY_AUTH_TOKEN=

# Local dev only
PORT=3141
